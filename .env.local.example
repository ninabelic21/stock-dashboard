# Copy to .env.local and fill in real values for local development.
# Never commit .env.local — it's gitignored.

# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google Cloud Console > APIs & Services > Credentials > OAuth Client ID (Web application)
# Authorized redirect URI must include: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# The only Google account allowed to sign in
ALLOWED_EMAIL=caroline.windisch@gmail.com

# finnhub.io free-tier API key
FINNHUB_API_KEY=
